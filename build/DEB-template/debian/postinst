#!/bin/sh
set -e

if ! dpkg -l python3-sounddevice 2>/dev/null | grep -q '^ii'; then
    echo ""
    echo "EasyPlayer: The spectrum analyzer requires the 'sounddevice' Python package,"
    echo "which is not available via apt on this distro. To enable it, run:"
    echo "  sudo pip install sounddevice --break-system-packages"
    echo ""
fi
